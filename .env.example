# All paths are optional. Relative defaults are rooted at the repository directory.
# METEOR_DATA_DIR=/absolute/path/to/meteor-quant/data
# METEOR_USER_STRATEGY_DIR=/absolute/path/to/meteor-quant/user_strategies
# METEOR_FRONTEND_DIST=/absolute/path/to/meteor-quant/frontend/dist
# METEOR_RUST_ENGINE_PATH=/absolute/path/to/meteor-engine

# Kraken public endpoints. Private credentials are intentionally unsupported.
# METEOR_KRAKEN_REST_URL=https://api.kraken.com
# METEOR_KRAKEN_WS_URL=wss://ws.kraken.com/v2
# METEOR_KRAKEN_TRADE_BOOTSTRAP_MAX_PAGES=120
# METEOR_KRAKEN_TRADE_BOOTSTRAP_PAGE_DELAY_SECONDS=0.15
